# Official Anthropic Messages API
UPSTREAM_BASE=https://api.anthropic.com

# Anthropic API key (ANTHROPIC_API_KEY also accepted)
UPSTREAM_KEY=sk-ant-your-key-here

# Model that returns thinking signatures (Sonnet / Opus 4.x / 5.x)
MODEL=claude-sonnet-4-6

# Max output tokens per request (raise for hard problems so reasoning isn't truncated)
MAX_TOKENS=64000

# Harvest reasoning effort: low | medium | high. Higher = more hidden thinking sealed into
# the signature (but slower / more likely to hit gateway timeouts on hard problems).
EFFORT=high

# Max chars accepted in the pasted-signature field. Signature length grows with the amount
# of hidden thinking (tens of thousands of chars for long traces), so keep this generous.
SIGNATURE_MAX_CHARS=200000

# Unseal dump: per-chunk output budget + auto-continuation rounds after max_tokens cuts
UNSEAL_CHUNK_TOKENS=8000
UNSEAL_MAX_CONTINUES=12
HTTP_TIMEOUT=1200

# Listen port
PORT=8000

# Per-IP daily quotas
PROVE_DAILY=20
LIVE_DAILY=40

# Where to write logs (conversation, signatures, raw responses)
LOG_DIR=./logs

# Optional: override per-model prices (USD per 1,000,000 tokens)
# PRICES_JSON={"claude-opus-4-8":{"input":15,"output":75},"claude-sonnet-4-6":{"input":3,"output":15}}
